{
  "name": "landing",
  "version": "1.0.0",
  "description": "This is a simple static website that serves as the official landing page for the \"HearMe\" project.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint --config .github/linters/.htmlhintrc \"src/**/*.html\" --ignore \"src/components/**\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint \"src/**/*.js\" \"build.js\"",
    "build": "npm run build:js && npm run build:css",
    "build:css": "BROWSERSLIST_IGNORE_OLD_DATA=true tailwindcss -i ./src/styles/input.css -o ./public/css/tailwind.css --minify",
    "build:js": "node build.js",
    "serve": "firebase serve --only hosting",
    "dev": "npm run build && npm run serve",
    "deploy": "npm run build && firebase deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HearMeTech/landing-page.git"
  },
  "keywords": [],
  "author": "HearMeTech",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HearMeTech/landing-page/issues"
  },
  "homepage": "https://github.com/HearMeTech/landing-page#readme",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001780",
    "cheerio": "^1.2.0",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "htmlhint": "^1.7.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^3.4.17"
  }
}
